# --- Mode ---------------------------------------------------------------
# When true, every LLM call and every retrieval call is served from
# deterministic fixtures. No network access is made. Tests always run with
# this set to true (enforced by a socket-blocking pytest fixture).
MOCK_MODE=true

# --- Groq (free tier only, no paid APIs) ---------------------------------
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TEMPERATURE=0.0

# --- Database -------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=veritas
POSTGRES_PASSWORD=veritas_dev_password
POSTGRES_DB=veritas
DATABASE_URL=postgresql+asyncpg://veritas:veritas_dev_password@localhost:5432/veritas

# --- Embeddings ------------------------------------------------------------
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DEVICE=cpu

# --- Web search (free, unofficial DuckDuckGo wrapper) ----------------------
WEB_SEARCH_PROVIDER=duckduckgo   # duckduckgo | mock
WEB_SEARCH_MAX_RESULTS=5

# --- Retrieval ---------------------------------------------------------------
RETRIEVAL_TOP_K_CORPUS=6
RETRIEVAL_TOP_K_WEB=5
RETRIEVAL_DEDUP_SIMILARITY_THRESHOLD=0.95

# --- Graph execution -------------------------------------------------------
NODE_TIMEOUT_SECONDS=30
GROQ_MAX_RETRIES=3
GROQ_BACKOFF_BASE_SECONDS=1.0
STANCE_SCHEMA_REPAIR_MAX_RETRIES=2

# --- Cache -------------------------------------------------------------------
PROMPT_VERSION=v1

# --- App ---------------------------------------------------------------------
APP_ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000

# --- Frontend (frontend/.env.local mirrors these) ---------------------------
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
